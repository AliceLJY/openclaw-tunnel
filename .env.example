# === task-api (runs in Docker) ===
WORKER_TOKEN=           # Required. Shared auth token (min 16 chars). Generated by setup.sh.
PORT=3456               # task-api listen port
CALLBACK_BOT_TOKEN=     # Required. Discord bot token (or platform equivalent) for result delivery.
CALLBACK_API_BASE_URL=https://discord.com/api/v10  # Change for non-Discord platforms.

# === runner (runs on host) ===
WORKER_URL=http://localhost:3456   # task-api URL from host's perspective
CLAUDE_PATH=claude                 # Claude Code CLI binary path
CC_TIMEOUT=1200000                 # Claude Code execution timeout in ms (default: 20 min)
